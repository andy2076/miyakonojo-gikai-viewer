# データベース接続 (Docker内のPostgreSQLコンテナ)
DB_HOST=172.17.0.1
DB_PORT=5432
DB_NAME=gikai
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# 管理者認証
ADMIN_PASSWORD=your_admin_password_here
SESSION_SECRET=your_random_session_secret_here

# ファイルアップロード先
UPLOAD_DIR=/root/miyakonojo-gikai-viewer/data/uploads

# Next.js
PORT=3000
NODE_ENV=production
